# Copy to .env and adjust as needed:  cp .env.example .env

# --- MinIO (S3 lakehouse storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Producer ---
# Target events per second the producer aims to sustain.
TARGET_EPS=10000
# If true, the producer seeds prices from a live NSE/Yahoo feed on startup,
# then generates realistic ticks around them. If false, pure synthetic.
USE_LIVE_FEED=true
